    dihedral_coeff @dihedral:EC_C6_O4_C2_H3 0.000 0.000 0.198 0.000
  }

  write_once("In Settings") {
    improper_coeff @improper:EC_C2_H1_H3_O4 0.000 -1 2
    improper_coeff @improper:EC_C2_H1_H3_C5 0.000 -1 2
    improper_coeff @improper:EC_C5_C2_H7_H8 0.000 -1 2
    improper_coeff @improper:EC_C5_O9_C2_H7 0.000 -1 2
    improper_coeff @improper:EC_C6_O9_O10_O4 10.500 -1 2
