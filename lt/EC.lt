    pair_coeff @atom:H8 @atom:H8 0.030 2.5000000
    pair_coeff @atom:O9 @atom:O9 0.140 2.9000000
    pair_coeff @atom:O10 @atom:O10 0.210 2.9600000
  }

  write_once("In Settings") {
    bond_coeff @bond:EC_C2_H1 340.0000 1.0900
    bond_coeff @bond:EC_H3_C2 340.0000 1.0900
    bond_coeff @bond:EC_O4_C2 320.0000 1.4100
    bond_coeff @bond:EC_C5_C2 268.0000 1.5290
    bond_coeff @bond:EC_C6_O4 214.0000 1.3270
    bond_coeff @bond:EC_H7_C5 340.0000 1.0900
    bond_coeff @bond:EC_H8_C5 340.0000 1.0900
    bond_coeff @bond:EC_O9_C5 320.0000 1.4100
    bond_coeff @bond:EC_O10_C6 570.0000 1.2290
    bond_coeff @bond:EC_O9_C6 214.0000 1.3270
  }

  write_once("In Settings") {
    angle_coeff @angle:EC_H1_C2_H3 33.000 107.800
    angle_coeff @angle:EC_H1_C2_O4 35.000 109.500
    angle_coeff @angle:EC_H1_C2_C5 37.500 110.700
    angle_coeff @angle:EC_C2_O4_C6 83.000 116.900
    angle_coeff @angle:EC_C2_C5_H7 37.500 110.700
    angle_coeff @angle:EC_C2_C5_H8 37.500 110.700
    angle_coeff @angle:EC_C2_C5_O9 50.000 109.500
    angle_coeff @angle:EC_O4_C6_O10 83.000 123.400
    angle_coeff @angle:EC_O4_C2_C5 50.000 109.500
    angle_coeff @angle:EC_H3_C2_O4 35.000 109.500
    angle_coeff @angle:EC_O9_C6_O10 83.000 123.400
    angle_coeff @angle:EC_H7_C5_O9 35.000 109.500
    angle_coeff @angle:EC_H3_C2_C5 37.500 110.700
    angle_coeff @angle:EC_H8_C5_O9 35.000 109.500
    angle_coeff @angle:EC_C5_O9_C6 83.000 116.900
    angle_coeff @angle:EC_O4_C6_O9 69.900 118.180
    angle_coeff @angle:EC_H7_C5_H8 33.000 107.800
  }

  write_once("In Settings") {
    dihedral_coeff @dihedral:EC_C6_O4_C2_H1 0.000 0.000 0.198 0.000
    dihedral_coeff @dihedral:EC_H7_C5_C2_H1 0.000 0.000 0.300 0.000
    dihedral_coeff @dihedral:EC_O9_C5_C2_H3 0.000 0.000 0.468 0.000
    dihedral_coeff @dihedral:EC_C5_O9_C6_O4 4.669 5.124 0.000 0.000
    dihedral_coeff @dihedral:EC_O10_C6_O4_C2 0.000 5.124 0.000 0.000
    dihedral_coeff @dihedral:EC_H7_C5_O9_C6 0.000 0.000 0.198 0.000
    dihedral_coeff @dihedral:EC_O10_C6_O9_C5 0.000 5.124 0.000 0.000
    dihedral_coeff @dihedral:EC_C6_O4_C2_C5 -1.220 -0.126 0.422 0.000
    dihedral_coeff @dihedral:EC_O9_C6_O4_C2 4.669 5.124 0.000 0.000
    dihedral_coeff @dihedral:EC_H7_C5_C2_O4 0.000 0.000 0.468 0.000
    dihedral_coeff @dihedral:EC_H8_C5_O9_C6 0.000 0.000 0.198 0.000
    dihedral_coeff @dihedral:EC_O9_C5_C2_O4 -0.550 0.000 0.000 0.000
    dihedral_coeff @dihedral:EC_H8_C5_C2_O4 0.000 0.000 0.468 0.000
    dihedral_coeff @dihedral:EC_H8_C5_C2_H1 0.000 0.000 0.300 0.000
    dihedral_coeff @dihedral:EC_H8_C5_C2_H3 0.000 0.000 0.300 0.000
    dihedral_coeff @dihedral:EC_H7_C5_C2_H3 0.000 0.000 0.300 0.000
