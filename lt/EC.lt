EC {

  ### LAMMPS commands for initialization
  ### (These can be overridden later.)


  write_once("In Init") {
    atom_style full
  }

  write_once("In Settings") {
    pair_coeff @atom:H1 @atom:H1 0.030 2.5000000
    pair_coeff @atom:C2 @atom:C2 0.066 3.5000000
    pair_coeff @atom:H3 @atom:H3 0.030 2.5000000
    pair_coeff @atom:O4 @atom:O4 0.140 2.9000000
    pair_coeff @atom:C5 @atom:C5 0.066 3.5000000
